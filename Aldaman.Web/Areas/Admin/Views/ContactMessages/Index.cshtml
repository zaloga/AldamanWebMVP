@using Aldaman.Persistence.Enums
@using Aldaman.Services.Dtos.ContactMessage
@model PagedResultDto<ContactMessageDto>
@{
    ViewData["Title"] = Localizer["ContactMessages"];
    var query = ViewData["Query"] as PaginationQuery ?? new PaginationQuery();
    var deletedItems = ViewBag.DeletedItems as PagedResultDto<ContactMessageDto>;
    var deletedQuery = ViewData["DeletedQuery"] as PaginationQuery ?? new PaginationQuery();
}

<div class="admin-card mb-4 p-3 bg-white border rounded-4">
    <form method="get" class="row g-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </span>
                <input type="text" name="SearchTerm" class="form-control border-start-0" placeholder="@Localizer["Search"]..." value="@query.SearchTerm">
            </div>
        </div>
        <div class="col-md-3">
            <select name="SortBy" class="form-select">
                <option value="CreatedAt" selected="@(query.SortBy == "CreatedAt")">@Localizer["SortByDate"]</option>
                <option value="State" selected="@(query.SortBy == "State")">@Localizer["SortByStatus"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="SortDescending" class="form-select">
                <option value="true" selected="@(query.SortDescending == true)">@Localizer["Descending"]</option>
                <option value="false" selected="@(query.SortDescending == false)">@Localizer["Ascending"]</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-secondary">@Localizer["Filter"]</button>
        </div>
    </form>
</div>

<div class="admin-card bg-white border rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 25%">@Localizer["Sender"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Subject"] / @Localizer["Message"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-center">@Localizer["Status"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-center">@Localizer["Date"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">@Localizer["NoItemsFound"]</td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    <tr id="row-@item.Id">
                        <td class="ps-4 py-3">
                            <div class="fw-semibold text-dark">@item.EmailOrPhone</div>
                        </td>
                        <td class="py-3">
                            <div class="fw-medium text-dark text-truncate" style="max-width: 300px;">@(string.IsNullOrEmpty(item.Subject) ? Localizer["NoSubject"].Value : item.Subject)</div>
                            <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Message</div>
                        </td>
                        <td class="py-3 text-center">
                            @switch (item.State)
                            {
                                case ContactMessageState.Pending:
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">@Localizer["Pending"]</span>
                                    break;
                                case ContactMessageState.Sent:
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">@Localizer["Handled"]</span>
                                    break;
                                case ContactMessageState.Failed:
                                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">@Localizer["Failed"]</span>
                                    break;
                            }
                        </td>
                        <td class="py-3 text-center">
                            <div class="small">@item.CreatedAtUtc.ToLocalTime().ToString("d. M. yyyy")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@item.CreatedAtUtc.ToLocalTime().ToString("HH:mm")</div>
                        </td>
                        <td class="py-3 text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1" asp-action="Details" asp-route-id="@item.Id">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    @Localizer["View"]
                                </a>
                                @if (item.State == ContactMessageState.Pending)
                                {
                                    <form asp-action="MarkHandled" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1">
                                            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            @Localizer["Handle"]
                                        </button>
                                    </form>
                                }
                                <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="deleteItem('@item.Id', '@item.EmailOrPhone')">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    @Localizer["Delete"]
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-4 pb-4">
        @await Html.PartialAsync("_AdminPagination", Model)
    </div>
</div>

@if (deletedItems != null && deletedItems.TotalCount > 0)
{
    <div class="mt-5 mb-4">
        <h3 class="h5 text-danger d-flex align-items-center gap-2">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            @Localizer["DeletedMessages"]
        </h3>
    </div>

    <div class="admin-card bg-white border rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 25%">@Localizer["Sender"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Subject"] / @Localizer["Message"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">@Localizer["Status"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">@Localizer["Date"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in deletedItems.Items)
                    {
                        <tr id="row-deleted-@item.Id">
                            <td class="ps-4 py-3">
                                <div class="fw-semibold text-muted text-decoration-line-through">@item.EmailOrPhone</div>
                            </td>
                            <td class="py-3">
                                <div class="fw-medium text-muted text-truncate" style="max-width: 300px;">@(string.IsNullOrEmpty(item.Subject) ? Localizer["NoSubject"].Value : item.Subject)</div>
                                <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Message</div>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">@Localizer["DeletedBadge"]</span>
                            </td>
                            <td class="py-3 text-center">
                                <div class="small text-muted">@item.CreatedAtUtc.ToLocalTime().ToString("d. M. yyyy")</div>
                            </td>
                            <td class="py-3 text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1" asp-action="Details" asp-route-id="@item.Id" title="@Localizer["View"]">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        @Localizer["View"]
                                    </a>
                                    <button class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1" onclick="restoreItem('@item.Id', '@item.EmailOrPhone')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        @Localizer["Restore"]
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="hardDeleteItem('@item.Id', '@item.EmailOrPhone')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        @Localizer["DeletePermanently"]
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4">
            @{
                ViewData["PageParamName"] = "deleted.Page";
                await Html.PartialAsync("_AdminPagination", deletedItems);
                ViewData["PageParamName"] = null;
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeleteMessageText"]'.replace('{0}', title),
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["YesDeleteIt"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }

        function restoreItem(id, title) {
            $.ajax({
                url: '@Url.Action("Restore")',
                type: 'POST',
                data: { 
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        Swal.fire('@Localizer["RestoredSuccessfully"]', response.message, 'success').then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('@Localizer["Error"]', response.message, 'error');
                    }
                },
                error: function() {
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                }
            });
        }

        function hardDeleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeletePermanentlyMessageText"]'.replace('{0}', title),
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["DeletePermanentlyButton"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("HardDelete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
