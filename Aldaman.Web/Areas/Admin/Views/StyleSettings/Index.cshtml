@model List<Aldaman.Services.Dtos.StyleSettings.StyleSettingDto>
@using Aldaman.Persistence.Enums

@{
    ViewData["Title"] = "Style Settings";
    var deletedItems = ViewBag.DeletedItems as List<Aldaman.Services.Dtos.StyleSettings.StyleSettingDto>;
}

<div class="mb-4">
    <a asp-action="Update" class="btn btn-success>
        <svg width="16" height="16" class="me-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Create New Setting
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Customize Theme Variables</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Key</th>
                        <th>Type</th>
                        <th>Value</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var setting in Model)
                    {
                        <tr id="row-@setting.Id">
                            <td><code>@setting.Key</code></td>
                            <td>@setting.Type</td>
                            <td>
                                <form asp-action="UpdateInline" method="post" class="d-flex align-items-center gap-2 m-0">
                                    <input type="hidden" name="id" value="@setting.Id" />
                                    
                                    @if (setting.Type == CssType.Color)
                                    {
                                        <input type="color" name="value" class="form-control form-control-color" value="@setting.Value" title="Choose color">
                                        <input type="text" class="form-control" value="@setting.Value" disabled style="width: 100px;" />
                                    }
                                    else
                                    {
                                        <input type="text" name="value" class="form-control" value="@setting.Value" />
                                    }
                                    
                                    <div class="btn-group btn-group-sm">
                                        <button type="submit" class="btn btn-success">Save</button>
                                        <button type="button" class="btn btn-outline-secondary" onclick="resetToDefault('@setting.Id', '@setting.Key', '@setting.DefaultValue')" title="Reset to default (@setting.DefaultValue)">
                                            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        </button>
                                    </div>
                                </form>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="UpdatePage" asp-route-id="@setting.Id" class="btn btn-outline-primary btn-sm" title="Edit Full">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <button class="btn btn-outline-danger btn-sm" onclick="deleteItem('@setting.Id', '@setting.Key')" title="Delete">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (deletedItems != null && deletedItems.Any())
{
    <div class="mt-5 mb-4">
        <h3 class="h5 text-danger d-flex align-items-center gap-2">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            Deleted Settings
        </h3>
    </div>

    <div class="card shadow-md border rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Key</th>
                        <th>Type</th>
                        <th>Value</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in deletedItems)
                    {
                        <tr id="row-deleted-@item.Id">
                            <td><code class="text-muted text-decoration-line-through">@item.Key</code></td>
                            <td>@item.Type</td>
                            <td><span class="text-muted">@item.Value</span></td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-outline-success btn-sm" onclick="restoreItem('@item.Id', '@item.Key')">
                                        Restore
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="hardDeleteItem('@item.Id', '@item.Key')">
                                        Permanently Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, key) {
            Swal.fire({
                title: 'Are you sure?',
                text: `Do you want to delete the setting ${key}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error!', 'An error occurred while deleting.', 'error');
                        }
                    });
                }
            });
        }

        function resetToDefault(id, key, defaultValue) {
            Swal.fire({
                title: 'Reset to Default?',
                text: `Do you want to reset the setting ${key} to its default value: ${defaultValue}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, reset it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ResetToDefault")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Reset!', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error!', 'An error occurred while resetting.', 'error');
                        }
                    });
                }
            });
        }

        function restoreItem(id, key) {
            $.ajax({
                url: '@Url.Action("Restore")',
                type: 'POST',
                data: { 
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        Swal.fire('Restored!', response.message, 'success').then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function() {
                    Swal.fire('Error!', 'An error occurred while restoring.', 'error');
                }
            });
        }

        function hardDeleteItem(id, key) {
            Swal.fire({
                title: 'Are you sure?',
                text: `Do you want to permanently delete the setting ${key}? This action cannot be undone.`,
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, delete permanently'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("HardDelete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error!', 'An error occurred while deleting permanently.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
