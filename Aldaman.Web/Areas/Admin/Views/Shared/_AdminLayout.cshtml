<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - Aldaman</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="h-100">
    <div class="container-fluid py-2 px-3">
        <!-- Header -->
        <header class="mb-2">
            <div class="d-flex align-items-center gap-3 py-2">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index" asp-route-culture="@ViewContext.RouteData.Values["culture"]" class="text-decoration-none text-dark d-flex align-items-center me-4">
                    <span class="h5 mb-0 fw-bold">@Localizer["Admin"]</span>
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Index" asp-route-culture="@ViewContext.RouteData.Values["culture"]" class="btn btn-link btn-sm text-secondary p-0 text-decoration-none d-flex align-items-center">
                    @Localizer["GoToWeb"]
                </a>
                @await Component.InvokeAsync("LanguageSwitcher", new { viewName = "Admin" })
                <span class="small fw-medium text-muted">@Localizer["AdminUser"]</span>
                <form asp-area="" asp-controller="Account" asp-action="Logout" asp-route-culture="@ViewContext.RouteData.Values["culture"]" method="post" class="d-inline line-height-21">
                    <button type="submit" class="btn btn-link btn-sm text-primary fw-medium p-0 text-decoration-none">@Localizer["SignOut"]</button>
                </form>
            </div>
        </header>

        <!-- Main Content Area -->
        <main>
            <partial name="_Breadcrumbs" />
            <partial name="_FlashMessages" />
            <partial name="_ValidationSummary" />
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
