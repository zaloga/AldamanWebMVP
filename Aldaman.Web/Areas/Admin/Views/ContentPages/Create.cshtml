@using Aldaman.Persistence.Enums
@model Aldaman.Services.Dtos.Page.ContentPageEditDto

@{
    ViewData["Title"] = Localizer["CreatePage"];
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">
            @Localizer["BackToList"]
        </a>
    </div>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">@Localizer["Translations"]</h6>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs mb-3" id="translationTabs" role="tablist">
                            @for (int i = 0; i < Model.Translations.Count; i++)
                            {
                                var culture = Model.Translations[i].CultureCode;
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link @(i == 0 ? "active" : "")" id="tab-@culture" data-bs-toggle="tab" data-bs-target="#content-@culture" type="button" role="tab" aria-controls="content-@culture" aria-selected="@(i == 0 ? "true" : "false")">
                                        @culture.ToUpper()
                                    </button>
                                </li>
                            }
                        </ul>
                        <div class="tab-content" id="translationTabsContent">
                            @for (int i = 0; i < Model.Translations.Count; i++)
                            {
                                var culture = Model.Translations[i].CultureCode;
                                <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="content-@culture" role="tabpanel" aria-labelledby="tab-@culture">
                                    <input type="hidden" asp-for="Translations[i].CultureCode" />
                                    
                                    <div class="mb-3">
                                        <label asp-for="Translations[i].Title" class="form-label">@Localizer["Title"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Title" class="form-control" />
                                        <span asp-validation-for="Translations[i].Title" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].Slug" class="form-label">@Localizer["Slug"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Slug" class="form-control" />
                                        <span asp-validation-for="Translations[i].Slug" class="text-danger"></span>
                                        <small class="text-muted">@Localizer["SlugInfo"]</small>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].BodyHtml" class="form-label">@Localizer["Content"] (@culture.ToUpper())</label>
                                        <div class="quill-editor-container bg-white" data-culture="@culture" data-index="@i" style="min-height: 400px;"></div>
                                        <input type="hidden" asp-for="Translations[i].BodyHtml" />
                                        <span asp-validation-for="Translations[i].BodyHtml" class="text-danger"></span>
                                    </div>
                                    
                                    <input type="hidden" asp-for="Translations[i].BodyDeltaJson" />
                                    <input type="hidden" asp-for="Translations[i].PlainText" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">@Localizer["Settings"]</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="PageKey" class="form-label fw-bold">@Localizer["PageKey"]</label>
                            <input asp-for="PageKey" class="form-control" placeholder="about-us" />
                            <span asp-validation-for="PageKey" class="text-danger"></span>
                            <small class="text-muted">@Localizer["PageKeyInfo"]</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-block text-primary fw-bold">@Localizer["Locations"]</label>
                            @foreach (var value in Enum.GetValues<PlaceToShowEnum>().Where(v => v != PlaceToShowEnum.None))
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="checkbox" name="PlaceToShow" value="@value" id="loc-@value" @(Model.PlaceToShow.HasFlag(value) ? "checked" : "")>
                                    <label class="form-check-label" for="loc-@value">
                                        @if (value == PlaceToShowEnum.HomePage) { <text>@Localizer["HomePage"]</text> }
                                        else if (value == PlaceToShowEnum.TopNavigation) { <text>@Localizer["TopNavigation"]</text> }
                                        else if (value == PlaceToShowEnum.Footer) { <text>@Localizer["Footer"]</text> }
                                        else { @value }
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="PageOrder" class="form-label">@Localizer["Order"]</label>
                            <input asp-for="PageOrder" class="form-control" type="number" />
                            <span asp-validation-for="PageOrder" class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-block">@Localizer["Create"]</button>
                            <a asp-action="Index" class="btn btn-secondary btn-block">@Localizer["Cancel"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/quill/quill.js"></script>
    <script src="~/js/admin-quill.js" asp-append-version="true"></script>
}
