@using Aldaman.Persistence.Enums
@model Aldaman.Services.Dtos.Page.ContentPageEditDto

@{
    var isCreate = Model.Id == null || Model.Id == Guid.Empty;
    ViewData["Title"] = isCreate ? Localizer["CreatePage"] : Localizer["EditPage"];
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">
            @Localizer["BackToList"]
        </a>
    </div>

    <form asp-action="@(isCreate ? "Create" : "Update")" method="post">
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
        }
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4 border-0">
                    <div class="card-header py-3 bg-white border-0">
                        <h6 class="m-0 fw-bold text-primary">@Localizer["Translations"]</h6>
                    </div>
                    <div class="card-body">
                        <partial name="_TranslationTabs" model="Model.Translations.Select(t => t.CultureCode)" />
                        
                        <div class="tab-content" id="translationTabsContent">
                            @{
                                var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
                                var activeCulture = Model.Translations.Any(t => t.CultureCode == currentCulture) 
                                    ? currentCulture 
                                    : Model.Translations.FirstOrDefault()?.CultureCode;
                            }
                            @for (int i = 0; i < Model.Translations.Count; i++)
                            {
                                var culture = Model.Translations[i].CultureCode;
                                var isActive = culture == activeCulture;
                                <div class="tab-pane fade @(isActive ? "show active" : "")" id="content-@culture" role="tabpanel" aria-labelledby="tab-@culture">
                                    <input type="hidden" asp-for="Translations[i].CultureCode" />
                                    
                                    <div class="mb-4">
                                        <label asp-for="Translations[i].Title" class="form-label fw-medium">@Localizer["Title"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Title" class="form-control" placeholder="@Localizer["Title"] (@culture.ToUpper())..." />
                                        <span asp-validation-for="Translations[i].Title" class="text-danger"></span>
                                    </div>

                                    <div class="mb-4">
                                        <label asp-for="Translations[i].Slug" class="form-label fw-medium">@Localizer["Slug"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Slug" class="form-control" />
                                        <span asp-validation-for="Translations[i].Slug" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].BodyHtml" class="form-label fw-medium">@Localizer["Content"] (@culture.ToUpper())</label>
                                        <div class="quill-editor-container bg-white" data-culture="@culture" data-index="@i" style="height: 400px;"></div>
                                        <input type="hidden" asp-for="Translations[i].BodyHtml" />
                                        <span asp-validation-for="Translations[i].BodyHtml" class="text-danger"></span>
                                    </div>
                                    
                                    <input type="hidden" asp-for="Translations[i].BodyDeltaJson" />
                                    <input type="hidden" asp-for="Translations[i].PlainText" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow mb-4 border-0">
                    <div class="card-header py-3 bg-white border-0">
                        <h6 class="m-0 fw-bold text-primary">@Localizer["Settings"]</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label asp-for="PageKey" class="form-label fw-bold text-dark">@Localizer["PageKey"]</label>
                            <input asp-for="PageKey" class="form-control" />
                            <span asp-validation-for="PageKey" class="text-danger"></span>
                            <small class="text-muted">@Localizer["PageKeyInfo"]</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label d-block text-dark fw-bold">@Localizer["Locations"]</label>
                            <div class="p-3 border rounded bg-light">
                                @foreach (var value in Enum.GetValues<PlaceToShowEnum>().Where(v => v != PlaceToShowEnum.None))
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="PlaceToShow" value="@value" id="loc-@value" @(Model.PlaceToShow.HasFlag(value) ? "checked" : "")>
                                        <label class="form-check-label fw-medium" for="loc-@value">
                                            @if (value == PlaceToShowEnum.HomePage) { <text>@Localizer["HomePage"]</text> }
                                            else if (value == PlaceToShowEnum.TopNavigation) { <text>@Localizer["TopNavigation"]</text> }
                                            else if (value == PlaceToShowEnum.Footer) { <text>@Localizer["Footer"]</text> }
                                            else { @value }
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PageOrder" class="form-label fw-bold text-dark">@Localizer["Order"]</label>
                            <input asp-for="PageOrder" class="form-control" type="number" />
                            <span asp-validation-for="PageOrder" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2 fw-bold">@(isCreate ? Localizer["Create"] : Localizer["Save"])</button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2">@Localizer["Cancel"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/quill/quill.js"></script>
    <script src="~/js/admin-quill.js" asp-append-version="true"></script>
}
