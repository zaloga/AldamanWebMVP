@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Stats Cards -->
    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 ring-1 ring-gray-900/5 transition-transform hover:scale-105">
        <dt class="truncate text-sm font-medium text-gray-500">Total Pages</dt>
        <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">12</dd>
    </div>

    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 ring-1 ring-gray-900/5 transition-transform hover:scale-105">
        <dt class="truncate text-sm font-medium text-gray-500">Blog Posts</dt>
        <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">48</dd>
    </div>

    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 ring-1 ring-gray-900/5 transition-transform hover:scale-105">
        <dt class="truncate text-sm font-medium text-gray-500">Unread Messages</dt>
        <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">3</dd>
    </div>

    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 ring-1 ring-gray-900/5 transition-transform hover:scale-105">
        <dt class="truncate text-sm font-medium text-gray-500">Media Assets</dt>
        <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">124</dd>
    </div>
</div>

<div class="mt-8">
    <h2 class="text-base font-semibold leading-7 text-gray-900">Welcome to Aldaman Admin</h2>
    <p class="mt-1 text-sm leading-6 text-gray-600">This is your administrative dashboard where you can manage your website content.</p>
</div>
