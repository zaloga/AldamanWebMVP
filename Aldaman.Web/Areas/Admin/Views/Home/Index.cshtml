@model Aldaman.Services.Dtos.AdminDashboard.AdminDashboardStatsDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <!-- Stats Cards -->
    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Total Pages</h6>
                <h2 class="card-title mb-0 fw-bold">@Model.TotalPagesCount</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Published Posts</h6>
                <h2 class="card-title mb-0 fw-bold">@Model.PublishedBlogPostsCount</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Pending Messages</h6>
                <h2 class="card-title mb-0 fw-bold">@Model.PendingContactMessagesCount</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Media Assets Size</h6>
                <h2 class="card-title mb-0 fw-bold">@(Model.TotalMediaSizeInBytes / 1024 / 1024) MB</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12 col-xl-8">
        <h5 class="fw-bold text-dark mb-4">Welcome to Aldaman Admin</h5>
        <p class="text-secondary mb-4">This is your administrative dashboard where you can manage your website content.</p>
        
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">Recent Messages</h5>
            </div>
            <div class="card-body">
                @if (Model.LatestMessages.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Name</th>
                                    <th>Subject</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var message in Model.LatestMessages)
                                {
                                    <tr>
                                        <td>@message.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                        <td>@message.Name</td>
                                        <td>@(string.IsNullOrEmpty(message.Subject) ? "No Subject" : message.Subject)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No recent messages.</p>
                }
            </div>
        </div>
    </div>
</div>
