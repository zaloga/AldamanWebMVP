@model Aldaman.Services.Dtos.AdminDashboard.AdminDashboardStatsDto

@{
    ViewData["Title"] = Localizer["Dashboard"];
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="h4 mb-0 text-dark fw-bold">@Localizer["Dashboard"]</h2>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-xl-4 g-4 mb-5">

    <div class="col">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted text-uppercase fw-bold small tracking-wide">@Localizer["BlogPosts"]</span>
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex">
                        <i class="bi bi-journal-text fs-5"></i>
                    </div>
                </div>
                <h3 class="display-6 fw-bold text-dark mb-1">@Model.BlogPostsCount</h3>
                <div class="mt-auto pt-3 border-top d-flex justify-content-between">
                    <a asp-area="Admin" asp-controller="Blog" asp-action="Index" class="text-decoration-none fw-medium text-primary d-flex align-items-center gap-1 small">
                        Spravovat <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted text-uppercase fw-bold small tracking-wide">@Localizer["Pages"]</span>
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex">
                        <i class="bi bi-files fs-5"></i>
                    </div>
                </div>
                <h3 class="display-6 fw-bold text-dark mb-1">@Model.TotalPagesCount</h3>
                <div class="mt-auto pt-3 border-top">
                    <a asp-area="Admin" asp-controller="ContentPages" asp-action="Index" class="text-decoration-none fw-medium text-primary d-flex align-items-center gap-1 small">
                        Upravit web <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted text-uppercase fw-bold small tracking-wide">@Localizer["ContactMessages"]</span>
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex">
                        <i class="bi bi-envelope fs-5"></i>
                    </div>
                </div>
                <h3 class="display-6 fw-bold text-dark mb-1">@Model.ContactMessagesCount</h3>
                <div class="mt-auto pt-3 border-top">
                    <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index" class="text-decoration-none fw-medium text-primary d-flex align-items-center gap-1 small">
                        Zobrazit zprávy <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="text-muted text-uppercase fw-bold small tracking-wide">@Localizer["MediaLibrary"]</span>
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex">
                        <i class="bi bi-images fs-5"></i>
                    </div>
                </div>
                <div class="d-flex align-items-baseline gap-2 mb-1">
                    <h3 class="display-6 fw-bold text-dark mb-0">@Model.TotalMediaCount</h3>
                    <span class="text-muted small">souborů</span>
                </div>
                <p class="text-muted small mb-0">Zabráno @(Model.TotalMediaSizeInBytes / 1048576) MB</p>
                <div class="mt-auto pt-3 border-top">
                    <a asp-area="Admin" asp-controller="Media" asp-action="Index" class="text-decoration-none fw-medium text-primary d-flex align-items-center gap-1 small">
                        Otevřít galerii <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="text-dark fw-bold mb-3 mt-5">@Localizer["NextSettings"]</h4>

<div class="row row-cols-1 row-cols-sm-2 row-cols-xl-4 g-4 mb-5">
    <div class="col">
        <div class="card h-100 border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-secondary bg-opacity-10 text-secondary p-2 rounded-3">
                        <i class="bi bi-sliders fs-5"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Theme Settings</h5>
                </div>
                <p class="text-muted small mb-4">Manage CSS variables, colors, and the overall look of the site.</p>
                <a asp-area="Admin" asp-controller="StyleSettings" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 rounded-pill">
                    Upravit vzhled
                </a>
            </div>
        </div>
    </div>
</div>