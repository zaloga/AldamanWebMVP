@{
    ViewData["Title"] = "Dashboard";
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <!-- Stats Cards -->
    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Total Pages</h6>
                <h2 class="card-title mb-0 fw-bold">12</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Blog Posts</h6>
                <h2 class="card-title mb-0 fw-bold">48</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Unread Messages</h6>
                <h2 class="card-title mb-0 fw-bold">3</h2>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-0 shadow-sm stats-card">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted text-uppercase small fw-bold">Media Assets</h6>
                <h2 class="card-title mb-0 fw-bold">124</h2>
            </div>
        </div>
    </div>
</div>

<div class="mt-5">
    <h5 class="fw-bold text-dark">Welcome to Aldaman Admin</h5>
    <p class="text-secondary">This is your administrative dashboard where you can manage your website content.</p>
</div>
