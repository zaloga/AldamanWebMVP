@model Aldaman.Services.Dtos.AdminDashboard.AdminDashboardStatsDto

@{
    ViewData["Title"] = Localizer["Dashboard"];
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <!-- Stats Cards -->
    <div class="col">
        <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index">
            <div class="card h-100 shadow-md stats-card">
                <div class="card-body">
                    <h5 class="card-subtitle mb-2 text-muted text-uppercase fw-bold">@Localizer["ContactMessages"]</h5>
                    <h6 class="card-title mb-0">@Localizer["Total"] @Model.ContactMessagesCount</h6>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-area="Admin" asp-controller="Blog" asp-action="Index">
            <div class="card h-100 shadow-md stats-card">
                <div class="card-body">
                    <h5 class="card-subtitle mb-2 text-muted text-uppercase fw-bold">@Localizer["BlogPosts"]</h5>
                    <h6 class="card-title mb-0">@Localizer["Total"] @Model.BlogPostsCount</h6>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-area="Admin" asp-controller="ContentPages" asp-action="Index">
            <div class="card h-100 shadow-md stats-card">
                <div class="card-body">
                    <h5 class="card-subtitle mb-2 text-muted text-uppercase fw-bold">@Localizer["Pages"]</h5>
                    <h6 class="card-title mb-0">@Localizer["Total"] @Model.TotalPagesCount</h6>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-area="Admin" asp-controller="Media" asp-action="Index">
            <div class="card h-100 shadow-md stats-card">
                <div class="card-body">
                    <h5 class="card-subtitle mb-2 text-muted text-uppercase fw-bold">@Localizer["MediaLibrary"]</h5>
                    <h6 class="card-title mb-0">@Localizer["Total"] @(Model.TotalMediaCount)</h6>
                    <h6 class="card-title mb-0">@(Model.TotalMediaSizeInBytes / 1048576) MB</h6>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12 col-xl-6">
        <div class="card shadow-md mb-3">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">@Localizer["RecentMessages"]</h5>
            </div>
            <div class="card-body">
                @if (Model.LatestMessages.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["EmailOrPhone"]</th>
                                    <th>@Localizer["Subject"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var message in Model.LatestMessages)
                                {
                                    <tr>
                                        <td>@message.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                        <td>@message.EmailOrPhone</td>
                                        <td>@(string.IsNullOrEmpty(message.Subject) ? Localizer["NoSubject"].Value : message.Subject)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">@Localizer["NoRecentMessages"]</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card shadow-md mb-3">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">@Localizer["RecentBlogPosts"]</h5>
            </div>
            <div class="card-body">
                @if (Model.LatestBlogPosts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Title"]</th>
                                    <th>@Localizer["Status"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var post in Model.LatestBlogPosts)
                                {
                                    <tr>
                                        <td>@post.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                        <td>@post.Title</td>
                                        <td>
                                            @if (post.IsPublished)
                                            {
                                                <span class="badge bg-success">@Localizer["Published"]</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">@Localizer["Draft"]</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">@Localizer["NoRecentBlogPosts"]</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card shadow-md mb-3">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">@Localizer["RecentPages"]</h5>
            </div>
            <div class="card-body">
                @if (Model.LatestPages.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Title"]</th>
                                    <th>@Localizer["PageKey"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contentPage in Model.LatestPages)
                                {
                                    <tr>
                                        <td>@contentPage.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                        <td>@contentPage.Title</td>
                                        <td><span class="badge bg-light text-dark">@contentPage.PageKey</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">@Localizer["NoRecentPages"]</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card shadow-md mb-3">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">@Localizer["RecentMedia"]</h5>
            </div>
            <div class="card-body">
                @if (Model.LatestMedia.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["FileName"]</th>
                                    <th>@Localizer["Size"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var media in Model.LatestMedia)
                                {
                                    <tr>
                                        <td>@media.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (media.ContentType.StartsWith("image/"))
                                                {
                                                    <img src="@media.RelativePath" alt="@media.OriginalFileName" class="rounded me-2" style="width: 32px; height: 32px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light rounded d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/></svg>
                                                    </div>
                                                }
                                                <span class="text-truncate" style="max-width: 150px;" title="@media.OriginalFileName">@media.OriginalFileName</span>
                                            </div>
                                        </td>
                                        <td>@(media.FileSize / 1024) KB</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">@Localizer["NoRecentMedia"]</p>
                }
            </div>
        </div>
    </div>
</div>
