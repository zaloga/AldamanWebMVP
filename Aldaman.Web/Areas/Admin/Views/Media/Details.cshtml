@using Aldaman.Services.Dtos.Media
@model MediaAssetDto
@{
    ViewData["Title"] = Localizer["MediaDetails"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-0">@Localizer["MediaDetails"]</h2>
        <p class="text-muted small mb-0">@Localizer["MediaDetailsInfo"]</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary d-inline-flex align-items-center gap-2 shadow-sm">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            @Localizer["Edit"]
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 shadow-sm bg-white p-2 rounded">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            @Localizer["BackToList"]
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="bg-white shadow-sm border p-4 rounded-3 text-center mb-4">
            <h3 class="h6 fw-bold mb-3">@Localizer["AssetPreview"]</h3>
            <div class="bg-light rounded border border-2 border-dashed overflow-hidden d-flex align-items-center justify-content-center" style="min-height: 250px;">
                @if (Model.IsImage)
                {
                    <img src="@Model.RelativePath" class="img-fluid" style="object-fit: contain; max-height: 350px;" alt="@Model.AltText">
                }
                else if (Model.IsVideo)
                {
                    <video src="@Model.RelativePath" controls class="img-fluid" style="max-height: 350px;"></video>
                }
                else
                {
                    <svg width="64" height="64" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-muted"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                }
            </div>
            <div class="mt-3 text-break small font-monospace text-muted">@Model.RelativePath</div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="bg-white shadow-sm border p-4 rounded-3">
            <h3 class="h6 fw-bold mb-4 border-bottom pb-2">@Localizer["Metadata"]</h3>
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["OriginalFileName"]</div>
                <div class="col-sm-8">@Model.OriginalFileName</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["Title"]</div>
                <div class="col-sm-8">@(string.IsNullOrEmpty(Model.Title) ? "-" : Model.Title)</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["AltText"]</div>
                <div class="col-sm-8">@(string.IsNullOrEmpty(Model.AltText) ? "-" : Model.AltText)</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["ContentType"]</div>
                <div class="col-sm-8"><span class="badge bg-light text-dark border">@Model.ContentType</span></div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["FileSize"]</div>
                <div class="col-sm-8">@((Model.FileSize / 1024.0).ToString("N1")) KB</div>
            </div>
            
            @if (Model.IsImage && Model.Width.HasValue && Model.Height.HasValue)
            {
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold text-muted">@Localizer["Dimensions"]</div>
                    <div class="col-sm-8">@Model.Width x @Model.Height px</div>
                </div>
            }
            
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-muted">@Localizer["Uploaded"]</div>
                <div class="col-sm-8">@Model.UploadedAtUtc.ToLocalTime().ToString("g")</div>
            </div>

            <div class="d-flex justify-content-end gap-2 border-top pt-4 mt-4">
                 <button class="btn btn-outline-danger px-4" onclick="deleteItem('@Model.Id', '@Model.OriginalFileName')">@Localizer["Delete"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeleteText"]'.replace('{0}', title),
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["YesDeleteIt"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    window.location.href = '@Url.Action("Index")';
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
