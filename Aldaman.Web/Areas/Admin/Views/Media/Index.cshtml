@using Aldaman.Services.Dtos
@model PagedResultDto<MediaAssetDto>
@{
    ViewData["Title"] = "Media Assets";
    var query = ViewData["Query"] as PaginationQuery ?? new PaginationQuery();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-0">Media Library</h2>
    </div>
    <a asp-action="Upload" class="btn btn-primary d-inline-flex align-items-center gap-2">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        Upload File
    </a>
</div>

<div class="admin-card mb-4 p-3 bg-white shadow-sm border">
    <form method="get" class="row g-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </span>
                <input type="text" name="SearchTerm" class="form-control border-start-0" placeholder="Search by name, title or alt..." value="@query.SearchTerm">
            </div>
        </div>
        <div class="col-md-3">
            <select name="SortBy" class="form-select">
                <option value="UploadedAt" selected="@(query.SortBy == "UploadedAt")">Sort by Upload Date</option>
                <option value="FileName" selected="@(query.SortBy == "FileName")">Sort by Filename</option>
                <option value="Size" selected="@(query.SortBy == "Size")">Sort by Size</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="SortDescending" class="form-select">
                <option value="true" selected="@(query.SortDescending == true)">Descending</option>
                <option value="false" selected="@(query.SortDescending == false)">Ascending</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-secondary">Filter</button>
        </div>
    </form>
</div>

<div class="admin-card bg-white shadow-sm border overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 100px">Preview</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">File Info</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Dimensions / Size</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Uploaded</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">No media assets found.</td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    <tr id="row-@item.Id">
                        <td class="ps-4 py-3">
                            <div class="bg-light rounded border d-flex align-items-center justify-content-center overflow-hidden shadow-sm" style="width: 64px; height: 64px;">
                                @if (item.IsImage)
                                {
                                    <img src="@item.RelativePath" class="img-fluid" style="object-fit: cover; width: 100%; height: 100%;" alt="@item.AltText">
                                }
                                else
                                {
                                    <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-muted"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                }
                            </div>
                        </td>
                        <td class="py-3">
                            <div class="fw-semibold text-dark text-truncate" style="max-width: 250px;">@item.OriginalFileName</div>
                            <div class="small text-muted">@item.ContentType</div>
                        </td>
                        <td class="py-3">
                            @if (item.IsImage && item.Width.HasValue && item.Height.HasValue)
                            {
                                <div class="small fw-medium">@item.Width x @item.Height px</div>
                            }
                            <div class="small text-muted">@((item.FileSize / 1024.0).ToString("N1")) KB</div>
                        </td>
                        <td class="py-3">
                            <div class="small">@item.UploadedAtUtc.ToString("MMM dd, yyyy")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@item.UploadedAtUtc.ToString("HH:mm") UTC</div>
                        </td>
                        <td class="py-3 text-end pe-4">
                            <div class="dropdown">
                                <button class="btn btn-light btn-sm rounded-circle border shadow-sm p-1" type="button" data-bs-toggle="dropdown">
                                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><a class="dropdown-item d-flex align-items-center gap-2" asp-action="Edit" asp-route-id="@item.Id">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        Edit Metadata
                                    </a></li>
                                    <li><a class="dropdown-item d-flex align-items-center gap-2" href="@item.RelativePath" target="_blank">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                        Open Original
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><button class="dropdown-item d-flex align-items-center gap-2 text-danger" onclick="deleteItem('@item.Id', '@item.OriginalFileName')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        Delete
                                    </button></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-4 pb-4">
        @await Html.PartialAsync("_AdminPagination", Model)
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, title) {
            Swal.fire({
                title: 'Delete media?',
                text: `Are you sure you want to delete "${title}"? This file will be marked for permanent removal.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('Deleted!', response.message, 'success');
                                $(`#row-${id}`).fadeOut(400, function() { $(this).remove(); });
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
