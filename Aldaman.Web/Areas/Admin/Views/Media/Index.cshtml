@using Aldaman.Services.Dtos.Media
@model PagedResultDto<MediaAssetDto>
@{
    ViewData["Title"] = Localizer["MediaLibrary"];
    var query = ViewData["Query"] as PaginationQuery ?? new PaginationQuery();
    // var deletedItems = ViewBag.DeletedItems as PagedResultDto<MediaAssetDto>;
    // var deletedQuery = ViewData["DeletedQuery"] as PaginationQuery ?? new PaginationQuery();
}

@* commented out for now, can be added in the future when we have usecase for it
    <div class="mb-4">
    <a asp-action="Upload" class="btn btn-success">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        @Localizer["UploadMedia"]
    </a>
</div> *@

<div class="admin-card mb-4 p-3 bg-white border rounded-4">
    <form method="get" class="row g-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </span>
                <input type="text" name="SearchTerm" class="form-control border-start-0" placeholder="@Localizer["Search"]..." value="@query.SearchTerm">
            </div>
        </div>
        <div class="col-md-3">
            <select name="SortBy" class="form-select">
                <option value="UploadedAt" selected="@(query.SortBy == "UploadedAt")">@Localizer["SortByUploadDate"]</option>
                <option value="FileName" selected="@(query.SortBy == "FileName")">@Localizer["SortByFilename"]</option>
                <option value="Size" selected="@(query.SortBy == "Size")">@Localizer["SortBySize"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="SortDescending" class="form-select">
                <option value="true" selected="@(query.SortDescending == true)">@Localizer["Descending"]</option>
                <option value="false" selected="@(query.SortDescending == false)">@Localizer["Ascending"]</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-secondary">@Localizer["Filter"]</button>
        </div>
    </form>
</div>

<div class="admin-card bg-white border rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 120px">@Localizer["Preview"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["FileName"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Dimensions"] / @Localizer["Size"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Uploaded"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">@Localizer["NoItemsFound"]</td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    <tr id="row-@item.Id">
                        <td class="ps-4 py-3">
                            <div class="bg-light rounded border d-flex align-items-center justify-content-center overflow-hidden shadow-sm" style="width: 64px; height: 64px;">
                                @if (item.IsImage)
                                {
                                    <img src="@item.RelativePath" class="img-fluid" style="object-fit: cover; width: 100%; height: 100%;" alt="@item.AltText">
                                }
                                else
                                {
                                    <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-muted"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                }
                            </div>
                        </td>
                        <td class="py-3">
                            <div class="fw-semibold text-dark text-truncate" style="max-width: 250px;">@item.OriginalFileName</div>
                            <div class="small text-muted">@item.ContentType</div>
                        </td>
                        <td class="py-3">
                            @if (item.IsImage && item.Width.HasValue && item.Height.HasValue)
                            {
                                <div class="small fw-medium">@item.Width x @item.Height px</div>
                            }
                            <div class="small text-muted">@((item.FileSize / 1024.0).ToString("N1")) KB</div>
                        </td>
                        <td class="py-3">
                            <div class="small">@item.UploadedAtUtc.ToLocalTime().ToString("d. M. yyyy")</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@item.UploadedAtUtc.ToLocalTime().ToString("HH:mm")</div>
                        </td>
                        <td class="py-3 text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-outline-info btn-sm d-inline-flex align-items-center gap-1" asp-action="Details" asp-route-id="@item.Id" title="@Localizer["Details"]">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    @Localizer["Details"]
                                </a>
                                <a class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1" asp-action="Edit" asp-route-id="@item.Id" title="@Localizer["Edit"]">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    @Localizer["Edit"]
                                </a>
                                <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1" href="@item.RelativePath" target="_blank" title="@Localizer["View"]">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                    @Localizer["View"]
                                </a>
                                @* commented out for now, can be added in the future when we have usecase for it
                                    <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="deleteItem('@item.Id', '@item.OriginalFileName')" title="@Localizer["Delete"]">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    @Localizer["Delete"]
                                </button> *@
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-4 pb-4">
        @await Html.PartialAsync("_AdminPagination", Model)
    </div>
</div>

@* commented out for now, can be added in the future when we have usecase for it
    @if (deletedItems != null && deletedItems.TotalCount > 0)
{
    <div class="mt-5 mb-4">
        <h3 class="h5 text-danger d-flex align-items-center gap-2">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            @Localizer["DeletedAssets"]
        </h3>
    </div>

    <div class="admin-card bg-white border rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 100px">@Localizer["Preview"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["FileInfo"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Dimensions"] / @Localizer["Size"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["Uploaded"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in deletedItems.Items)
                    {
                        <tr id="row-deleted-@item.Id">
                            <td class="ps-4 py-3">
                                <div class="bg-light rounded border d-flex align-items-center justify-content-center overflow-hidden shadow-sm opacity-50" style="width: 64px; height: 64px;">
                                    @if (item.IsImage)
                                    {
                                        <img src="@item.RelativePath" class="img-fluid" style="object-fit: cover; width: 100%; height: 100%; filter: grayscale(100%);" alt="@item.AltText">
                                    }
                                    else
                                    {
                                        <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-muted"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                    }
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="fw-semibold text-muted text-decoration-line-through text-truncate" style="max-width: 250px;">@item.OriginalFileName</div>
                                <div class="small text-muted">@item.ContentType</div>
                            </td>
                            <td class="py-3">
                                @if (item.IsImage && item.Width.HasValue && item.Height.HasValue)
                                {
                                    <div class="small text-muted">@item.Width x @item.Height px</div>
                                }
                                <div class="small text-muted">@((item.FileSize / 1024.0).ToString("N1")) KB</div>
                            </td>
                            <td class="py-3">
                                <div class="small text-muted">@Localizer["Uploaded"]: @item.UploadedAtUtc.ToLocalTime().ToString("d. M. yyyy")</div>
                            </td>
                            <td class="py-3 text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1" onclick="restoreItem('@item.Id', '@item.OriginalFileName')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        @Localizer["Restore"]
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="hardDeleteItem('@item.Id', '@item.OriginalFileName')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        @Localizer["DeletePermanently"]
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4">
            @{
                ViewData["PageParamName"] = "deleted.Page";
                await Html.PartialAsync("_AdminPagination", deletedItems);
                ViewData["PageParamName"] = null;
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeleteText"]'.replace('{0}', title),
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["YesDeleteIt"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }

        function restoreItem(id, title) {
            $.ajax({
                url: '@Url.Action("Restore")',
                type: 'POST',
                data: { 
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        Swal.fire('@Localizer["RestoredSuccessfully"]', response.message, 'success').then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('@Localizer["Error"]', response.message, 'error');
                    }
                },
                error: function() {
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                }
            });
        }

        function hardDeleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeletePermanentlyText"]'.replace('{0}', title),
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["DeletePermanentlyButton"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("HardDelete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }
    </script>
} *@
