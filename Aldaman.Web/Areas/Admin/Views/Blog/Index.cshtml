@using Aldaman.Services.Dtos.Blog
@model PagedResultDto<BlogPostListItemDto>
@{
    ViewData["Title"] = Localizer["BlogPosts"];
    var query = ViewData["Query"] as PaginationQuery ?? new PaginationQuery();
    var deletedItems = ViewBag.DeletedItems as PagedResultDto<BlogPostListItemDto>;
    var deletedQuery = ViewData["DeletedQuery"] as PaginationQuery ?? new PaginationQuery();
}

<div class="mb-4">
    <a asp-action="Create" class="btn btn-success">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        @Localizer["Create"]
    </a>
</div>

<div class="admin-card mb-4 p-3 bg-white shadow-sm border">
    <form method="get" class="row g-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </span>
                <input type="text" name="SearchTerm" class="form-control border-start-0" placeholder="@Localizer["Search"]..." value="@query.SearchTerm">
            </div>
        </div>
        <div class="col-md-3">
            <select name="SortBy" class="form-select">
                <option value="CreatedAt" selected="@(query.SortBy == "CreatedAt")">@Localizer["SortByCreatedDate"]</option>
                <option value="Title" selected="@(query.SortBy == "Title")">@Localizer["SortByTitle"]</option>
                <option value="PublishedAt" selected="@(query.SortBy == "PublishedAt")">@Localizer["SortByPublishDate"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="SortDescending" class="form-select">
                <option value="true" selected="@(query.SortDescending == true)">@Localizer["Descending"]</option>
                <option value="false" selected="@(query.SortDescending == false)">@Localizer["Ascending"]</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-outline-secondary">@Localizer["Filter"]</button>
        </div>
    </form>
</div>

<div class="admin-card bg-white shadow-sm border overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 40%">@Localizer["Title"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["CreatedAt"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["UpdatedAt"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["PublicationDate"]</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">@Localizer["NoItemsFound"]</td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    <tr id="row-@item.Id">
                        <td class="ps-4 py-3">
                            <div class="fw-semibold text-dark">@item.Title</div>
                            <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Perex</div>
                        </td>
                        <td class="py-3 text-muted small">
                            @item.CreatedAtUtc.ToLocalTime().ToString("d. M. yyyy HH:mm")
                        </td>
                        <td class="py-3 text-muted small">
                            @(item.UpdatedAtUtc.HasValue ? item.UpdatedAtUtc.Value.ToLocalTime().ToString("d. M. yyyy HH:mm") : "-")
                        </td>
                        <td class="py-3">
                            @if (item.IsPublished && item.PublishedAtUtc.HasValue)
                            {
                                <span class="d-flex align-items-center text-success small fw-medium">
                                    <span class="bg-success rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                                    @string.Format(Localizer["PublishedOnDate"].Value, item.PublishedAtUtc.Value.ToLocalTime().ToString("d. M. yyyy"))
                                </span>
                            }
                            else
                            {
                                <span class="d-flex align-items-center text-warning small fw-medium">
                                    <span class="bg-warning rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                                    @Localizer["Draft"]
                                </span>
                            }
                        </td>
                        <td class="py-3 text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1" asp-action="Update" asp-route-id="@item.Id">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    @Localizer["Edit"]
                                </a>
                                <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1" asp-action="Details" asp-route-id="@item.Id">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    @Localizer["View"]
                                </a>
                                <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="deleteItem('@item.Id', '@item.Title')">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    @Localizer["Delete"]
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-4 pb-4">
        @await Html.PartialAsync("_AdminPagination", Model)
    </div>
</div>

@if (deletedItems != null && deletedItems.TotalCount > 0)
{
    <div class="mt-5 mb-4">
        <h3 class="h5 text-danger d-flex align-items-center gap-2">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            @Localizer["DeletedPosts"]
        </h3>
    </div>

    <div class="admin-card bg-white shadow-sm border overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 40%">@Localizer["Title"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["CreatedAt"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["UpdatedAt"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">@Localizer["PublicationDate"]</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-end pe-4">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in deletedItems.Items)
                    {
                        <tr id="row-deleted-@item.Id">
                            <td class="ps-4 py-3">
                                <div class="fw-semibold text-muted text-decoration-line-through">@item.Title</div>
                            </td>
                            <td class="py-3 text-muted small">
                                @item.CreatedAtUtc.ToLocalTime().ToString("d. M. yyyy HH:mm")
                            </td>
                            <td class="py-3 text-muted small">
                                @(item.UpdatedAtUtc.HasValue ? item.UpdatedAtUtc.Value.ToLocalTime().ToString("d. M. yyyy HH:mm") : "-")
                            </td>
                            <td class="py-3">
                                @if (item.IsPublished && item.PublishedAtUtc.HasValue)
                                {
                                    <span class="d-flex align-items-center text-success small fw-medium">
                                        <span class="bg-success rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                                        @string.Format(Localizer["PublishedOnDate"].Value, item.PublishedAtUtc.Value.ToLocalTime().ToString("d. M. yyyy"))
                                    </span>
                                }
                                else
                                {
                                    <span class="d-flex align-items-center text-warning small fw-medium">
                                        <span class="bg-warning rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                                        @Localizer["Draft"]
                                    </span>
                                }
                            </td>
                            <td class="py-3 text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-outline-success btn-sm d-inline-flex align-items-center gap-1" onclick="restoreItem('@item.Id', '@item.Title')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        @Localizer["Restore"]
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1" onclick="hardDeleteItem('@item.Id', '@item.Title')">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        @Localizer["DeletePermanently"]
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4">
            @{
                ViewData["PageParamName"] = "deleted.Page";
                await Html.PartialAsync("_AdminPagination", deletedItems);
                ViewData["PageParamName"] = null;
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeleteText"]'.replace('{0}', title),
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["YesDeleteIt"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }

        function restoreItem(id, title) {
            $.ajax({
                url: '@Url.Action("Restore")',
                type: 'POST',
                data: { 
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        Swal.fire('@Localizer["RestoredSuccessfully"]', response.message, 'success').then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('@Localizer["Error"]', response.message, 'error');
                    }
                },
                error: function() {
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                }
            });
        }

        function hardDeleteItem(id, title) {
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: '@Localizer["ConfirmDeletePermanentlyText"]'.replace('{0}', title),
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["DeletePermanentlyButton"]',
                cancelButtonText: '@Localizer["Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("HardDelete")',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire('@Localizer["DeletedSuccessfully"]', response.message, 'success').then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('@Localizer["Error"]', response.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('@Localizer["Error"]', '@Localizer["ErrorOccurred"]', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
