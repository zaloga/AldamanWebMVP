@model Aldaman.Services.Dtos.Blog.BlogPostEditDto

@{
    ViewData["Title"] = Localizer["BlogPostDetails"];
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
        <div>
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary">@Localizer["Edit"]</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">@Localizer["BackToList"]</a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["PostSettings"]</h6>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">@Localizer["IsPublished"]</dt>
                        <dd class="col-sm-6">
                            @if (Model.IsPublished)
                            {
                                <span class="badge bg-success">@Localizer["Published"]</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Localizer["Draft"]</span>
                            }
                        </dd>

                        <dt class="col-sm-6">@Localizer["PublishedAt"]</dt>
                        <dd class="col-sm-6 text-dark fw-medium">@(Model.PublishedAtUtc?.ToString("g") ?? "---")</dd>

                        <dt class="col-sm-6">@Localizer["CoverImageId"]</dt>
                        <dd class="col-sm-6 text-truncate text-muted">@(Model.CoverMediaAssetId?.ToString() ?? Localizer["None"].Value)</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">@Localizer["Translations"]</h6>
                </div>
                <div class="card-body">
                    @{
                        var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
                        var activeCulture = Model.Translations.Any(t => t.CultureCode == currentCulture) 
                            ? currentCulture 
                            : Model.Translations.FirstOrDefault()?.CultureCode;
                    }
                    <ul class="nav nav-tabs mb-3" id="detailsTabs" role="tablist">
                        @for (int i = 0; i < Model.Translations.Count; i++)
                        {
                            var culture = Model.Translations[i].CultureCode;
                            var isActive = culture == activeCulture;
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @(isActive ? "active" : "")" id="tab-@culture" data-bs-toggle="tab" data-bs-target="#content-@culture" type="button" role="tab" aria-controls="content-@culture" aria-selected="@(isActive ? "true" : "false")">
                                    @culture.ToUpper()
                                </button>
                            </li>
                        }
                    </ul>
                    <div class="tab-content" id="detailsTabsContent">
                        @for (int i = 0; i < Model.Translations.Count; i++)
                        {
                            var translation = Model.Translations[i];
                            var culture = translation.CultureCode;
                            var isActive = culture == activeCulture;
                            <div class="tab-pane fade @(isActive ? "show active" : "")" id="content-@culture" role="tabpanel" aria-labelledby="tab-@culture">
                                <dl class="row">
                                    <dt class="col-sm-2 text-muted small text-uppercase fw-bold">@Localizer["Title"]</dt>
                                    <dd class="col-sm-10 fw-bold text-dark">@(string.IsNullOrWhiteSpace(translation.Title) ? "---" : translation.Title)</dd>

                                    <dt class="col-sm-2 text-muted small text-uppercase fw-bold">@Localizer["Slug"]</dt>
                                    <dd class="col-sm-10 font-monospace small">@(string.IsNullOrWhiteSpace(translation.Slug) ? "---" : translation.Slug)</dd>

                                    <dt class="col-sm-2 text-muted small text-uppercase fw-bold">@Localizer["Perex"]</dt>
                                    <dd class="col-sm-10 text-muted italic">@(string.IsNullOrWhiteSpace(translation.Perex) ? "---" : translation.Perex)</dd>

                                    <dt class="col-sm-12 text-muted small text-uppercase fw-bold mt-3 mb-2">@Localizer["Content"]</dt>
                                    <dd class="col-sm-12">
                                        @if (!string.IsNullOrWhiteSpace(translation.BodyHtml))
                                        {
                                            <div class="p-4 border rounded bg-white shadow-sm ql-snow mb-3" style="max-height: 500px; overflow-y: auto;">
                                                <div class="ql-editor p-0">
                                                    @Html.Raw(translation.BodyHtml)
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="p-3 border rounded bg-light mb-3 text-muted">
                                                @Localizer["NoHtmlContent"]
                                            </div>
                                        }
                                    </dd>

                                    <dt class="col-sm-12 text-muted small text-uppercase fw-bold mt-3 mb-2">@Localizer["PlainText"]</dt>
                                    <dd class="col-sm-12">
                                        @if (!string.IsNullOrWhiteSpace(translation.PlainText))
                                        {
                                            <div class="p-3 border rounded bg-light" style="max-height: 200px; overflow-y: auto;">
                                                <pre class="mb-0 text-muted" style="white-space: pre-wrap; font-family: inherit; font-size: 0.875rem;">@translation.PlainText</pre>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="p-3 border rounded bg-light text-muted italic">
                                                @Localizer["NoPlainText"]
                                            </div>
                                        }
                                    </dd>
                                </dl>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
