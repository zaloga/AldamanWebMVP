@model Aldaman.Services.Dtos.Blog.BlogPostEditDto

@{
    ViewData["Title"] = Localizer["CreateBlogPost"];
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-secondary">
            @Localizer["BackToList"]
        </a>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">@Localizer["Translations"]</h6>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs mb-3" id="translationTabs" role="tablist">
                            @for (int i = 0; i < Model.Translations.Count; i++)
                            {
                                var culture = Model.Translations[i].CultureCode;
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link @(i == 0 ? "active" : "")" id="tab-@culture" data-bs-toggle="tab" data-bs-target="#content-@culture" type="button" role="tab" aria-controls="content-@culture" aria-selected="@(i == 0 ? "true" : "false")">
                                        @culture.ToUpper()
                                    </button>
                                </li>
                            }
                        </ul>
                        <div class="tab-content" id="translationTabsContent">
                            @for (int i = 0; i < Model.Translations.Count; i++)
                            {
                                var culture = Model.Translations[i].CultureCode;
                                <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="content-@culture" role="tabpanel" aria-labelledby="tab-@culture">
                                    <input type="hidden" asp-for="Translations[i].CultureCode" />
                                    
                                    <div class="mb-3">
                                        <label asp-for="Translations[i].Title" class="form-label">@Localizer["Title"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Title" class="form-control" />
                                        <span asp-validation-for="Translations[i].Title" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].Slug" class="form-label">@Localizer["Slug"] (@culture.ToUpper())</label>
                                        <input asp-for="Translations[i].Slug" class="form-control" placeholder="@culture.ToLower()/my-post" />
                                        <span asp-validation-for="Translations[i].Slug" class="text-danger"></span>
                                        <small class="text-muted">@Localizer["SlugInfo"]</small>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].Perex" class="form-label">@Localizer["Perex"] (@culture.ToUpper())</label>
                                        <textarea asp-for="Translations[i].Perex" class="form-control" rows="3"></textarea>
                                        <span asp-validation-for="Translations[i].Perex" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Translations[i].BodyHtml" class="form-label">@Localizer["Content"] (@culture.ToUpper())</label>
                                        <div class="quill-editor-container bg-white" data-culture="@culture" data-index="@i" style="height: 400px;"></div>
                                        <input type="hidden" asp-for="Translations[i].BodyHtml" />
                                        <span asp-validation-for="Translations[i].BodyHtml" class="text-danger"></span>
                                    </div>
                                    
                                    <input type="hidden" asp-for="Translations[i].BodyDeltaJson" />
                                    <input type="hidden" asp-for="Translations[i].PlainText" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">@Localizer["PostSettings"]</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch">
                                <label asp-for="IsPublished" class="form-check-label">@Localizer["IsPublished"]</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PublishedAtUtc" class="form-label">@Localizer["PublicationDate"]</label>
                            <input asp-for="PublishedAtUtc" class="form-control" type="datetime-local" />
                            <span asp-validation-for="PublishedAtUtc" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CoverImageFile" class="form-label fw-bold">@Localizer["CoverImage"]</label>
                            <div class="input-group">
                                <label class="input-group-text cursor-pointer" for="CoverImageFile">
                                    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="me-1"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                                    @Localizer["ChooseFile"]
                                </label>
                                <input asp-for="CoverImageFile" class="form-control d-none" type="file" accept="image/*" onchange="updateCoverFileName(this)" />
                                <span class="form-control bg-light text-muted" id="coverFileNameDisplay">@Localizer["NoFileChosen"]</span>
                            </div>
                            <span asp-validation-for="CoverImageFile" class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-block">@Localizer["Create"]</button>
                            <a asp-action="Index" class="btn btn-secondary btn-block">@Localizer["Cancel"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/quill/quill.js"></script>
    <script src="~/js/admin-quill.js" asp-append-version="true"></script>
    <script>
        function updateCoverFileName(input) {
            const display = document.getElementById('coverFileNameDisplay');
            if (input.files && input.files.length > 0) {
                display.textContent = input.files[0].name;
                display.classList.remove('text-muted');
            } else {
                display.textContent = '@Localizer["NoFileChosen"]';
                display.classList.add('text-muted');
            }
        }
    </script>
}
