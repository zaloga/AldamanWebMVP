@model Aldaman.Web.ViewModels.PageViewModel
@{
    ViewData["Title"] = Model.Page.SeoTitle ?? Model.Page.Title;
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl mb-8">@Model.Page.Title</h1>
    <div class="prose prose-lg prose-indigo text-gray-500">
        @if (!string.IsNullOrEmpty(Model.Page.SectionsJson))
        {
            <pre class="bg-gray-100 p-4 rounded-lg overflow-auto"><code>@Model.Page.SectionsJson</code></pre>
        }
        else
        {
            <p>Tato stránka momentálně nemá žádný obsah.</p>
        }
    </div>
</div>
