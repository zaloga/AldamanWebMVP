@model Aldaman.Web.Models.Account.LoginRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer[UIResourceKeys.Login];
}

<div class="h-[70vh] flex flex-col items-center justify-center p-6 text-slate-900 dark:text-slate-100 font-sans">
    <div class="w-full max-w-[340px] space-y-10">
        <div class="text-center">
            <h1 class="text-3xl font-light tracking-tight">Aldaman</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">@Localizer[UIResourceKeys.WelcomeToAdmin]</p>
        </div>

        <form asp-action="Login" method="post" class="space-y-6">
            <input type="hidden" asp-for="ReturnUrl" value="@ViewData["ReturnUrl"]" />
            
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm italic font-medium"></div>

            <div class="space-y-4">
                <div class="space-y-1">
                    <input asp-for="Email" required placeholder="@Localizer[UIResourceKeys.Email]" autocomplete="username"
                           class="w-full rounded-xl border border-slate-300/70 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 transition-all placeholder:text-slate-400 dark:placeholder:text-slate-500" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs px-1"></span>
                </div>

                <div class="space-y-1">
                    <input asp-for="Password" type="password" required placeholder="@Localizer[UIResourceKeys.Password]" autocomplete="current-password"
                           class="w-full rounded-xl border border-slate-300/70 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 transition-all placeholder:text-slate-400 dark:placeholder:text-slate-500" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs px-1"></span>
                </div>
            </div>

            <div class="flex items-center justify-between text-xs px-1">
                <label class="flex items-center gap-2 cursor-pointer opacity-70 hover:opacity-100 transition-opacity">
                    <input asp-for="RememberMe" class="rounded-md border-slate-300 text-indigo-600 focus:ring-indigo-500/30" />
                    @Localizer[UIResourceKeys.RememberMe]
                </label>
                <a href="#" class="text-indigo-600 dark:text-indigo-400 hover:underline">@Localizer[UIResourceKeys.ForgotPassword]</a>
            </div>

            <button type="submit" class="w-full rounded-xl bg-indigo-600 px-5 py-3 text-white font-medium shadow-lg shadow-indigo-500/20 hover:bg-indigo-700 transition-all active:scale-[0.98] transform">
                @Localizer[UIResourceKeys.SignInButton]
            </button>
        </form>

        <footer class="text-center opacity-30 text-[10px] uppercase tracking-widest pt-4">
            &copy; @DateTime.Today.Year Aldaman Web
        </footer>
    </div>
</div>

