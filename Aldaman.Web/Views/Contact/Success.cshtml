@{
    ViewData["Title"] = Localizer[UIResourceKeys.MessageSent];
}

<div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:py-24 lg:px-8 text-center">
    <h2 class="text-3xl font-extrabold text-green-600 mb-4">@Localizer[UIResourceKeys.ThankYouForMessage]</h2>
    <p class="text-xl text-gray-500 mb-8">@Localizer[UIResourceKeys.MessageSentConfirmation]</p>
    <a href="/" class="text-indigo-600 hover:text-indigo-500 font-medium border border-indigo-600 px-4 py-2 rounded-md">@Localizer[UIResourceKeys.BackToHome]</a>
</div>
