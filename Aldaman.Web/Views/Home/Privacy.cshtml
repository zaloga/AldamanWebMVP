@{
    ViewData["Title"] = "Privacy Policy";
}
<div class="max-w-3xl mx-auto py-10">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900 border-b border-slate-200 pb-4">
        @ViewData["Title"]
    </h1>

    <div class="mt-8 prose prose-slate">
        <p class="text-lg text-slate-600 leading-7">
            Use this page to detail your site's privacy policy. Aldaman is committed to protecting your personal data and ensuring a safe browsing experience.
        </p>
        
        <div class="mt-10 rounded-2xl bg-slate-50 p-8 border border-slate-100">
            <h2 class="text-xl font-semibold text-slate-900">Information Collection</h2>
            <p class="mt-4 text-slate-600">
                We collect only essential information required to provide our services and improve user experience. All data is handled according to modern security standards.
            </p>
        </div>
    </div>
</div>
