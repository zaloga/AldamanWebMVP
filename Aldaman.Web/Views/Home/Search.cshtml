@{
    ViewData["Title"] = "Search API for AI";
}

<div class="py-12 md:py-20 max-w-5xl mx-auto px-4">
    <!-- Header -->
    <header class="mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-brand-primary/10 text-brand-primary text-[10px] font-bold uppercase tracking-wider mb-4 border border-brand-primary/20">
            REST API
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-6 tracking-tight">
            Search API for <span class="text-brand-primary">Applications</span>
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl leading-relaxed">
            A high-performance REST API to retrieve content from Aldaman. Perfect for integrating search functionality into external tools, mobile apps, or custom AI agents.
        </p>
    </header>

    <!-- Content Sections -->
    <div class="space-y-16">
        <!-- Endpoint Section -->
        <section>
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-brand-primary rounded-full"></span>
                Endpoint
            </h2>
            <div class="flex items-center gap-4 bg-slate-50 dark:bg-slate-900/50 rounded-2xl p-6 border border-slate-200 dark:border-white/10">
                <span class="flex-shrink-0 px-3 py-1 bg-green-500 text-white rounded-md text-xs font-bold">GET</span>
                <code class="text-brand-primary dark:text-brand-accent font-mono text-sm">/api/search</code>
                <div class="ml-auto hidden md:block text-xs text-slate-400 font-mono">https://aldaman.cz/api/search</div>
            </div>
        </section>

        <!-- Parameters Section -->
        <section>
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-brand-accent rounded-full"></span>
                Query Parameters
            </h2>
            <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm bg-white dark:bg-slate-900/20">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 uppercase text-[10px] font-bold border-b border-slate-200 dark:border-white/10">
                        <tr>
                            <th class="px-6 py-4">Parameter</th>
                            <th class="px-6 py-4">Type</th>
                            <th class="px-6 py-4">Description</th>
                            <th class="px-6 py-4 text-right">Required</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-white/5">
                        <tr>
                            <td class="px-6 py-4 font-mono text-brand-primary font-semibold">query</td>
                            <td class="px-6 py-4 text-slate-500 dark:text-slate-400">string</td>
                            <td class="px-6 py-4 text-slate-700 dark:text-slate-300">The search term (minimum 2 characters).</td>
                            <td class="px-6 py-4 text-right">
                                <span class="px-2 py-0.5 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-[10px] font-bold uppercase">Yes</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 font-mono text-brand-primary font-semibold">culture</td>
                            <td class="px-6 py-4 text-slate-500 dark:text-slate-400">string</td>
                            <td class="px-6 py-4 text-slate-700 dark:text-slate-300">Target culture (e.g., "cs", "en").</td>
                            <td class="px-6 py-4 text-right">
                                <span class="text-slate-400 dark:text-slate-600 italic">No (Default: cs)</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Response Section -->
        <section>
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-slate-400 rounded-full"></span>
                Sample Response
            </h2>
            <div class="relative group">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-brand-primary/20 to-brand-accent/20 rounded-2xl blur opacity-30 group-hover:opacity-50 transition duration-1000"></div>
                <div class="relative bg-slate-900 rounded-2xl p-8 shadow-2xl overflow-hidden">
                    <div class="flex items-center gap-1.5 mb-6">
                        <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-amber-500/50"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/50"></div>
                    </div>
                    <pre class="font-mono text-xs md:text-sm text-slate-300 leading-relaxed overflow-x-auto"><code>{
  "count": 1,
  "query": "artificial intelligence",
  "culture": "en",
  "results": [
    {
      "title": "The Future of AI",
      "snippet": "Artificial Intelligence is transforming how we work...",
      "url": "https://aldaman.cz/en/blog/future-of-ai",
      "type": "BlogPost",
      "lastModified": "2024-05-15T10:00:00Z"
    }
  ]
}</code></pre>
                </div>
            </div>
        </section>

        <!-- Footer Note -->
        <footer class="pt-8 border-t border-slate-200 dark:border-white/10">
            <div class="flex items-start gap-4 p-6 bg-slate-50 dark:bg-slate-900/50 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 dark:text-white text-sm mb-1">Developer Guidelines</h4>
                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
                        This API is public and does not require authentication for standard read operations. To prevent abuse, please limit your requests to a reasonable frequency.
                    </p>
                </div>
            </div>
        </footer>
    </div>
</div>
