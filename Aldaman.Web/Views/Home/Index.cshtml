@using Aldaman.Services.Dtos.Page
@model IEnumerable<ContentPageDetailDto>
@{
    ViewData["Title"] = Localizer[UIResourceKeys.Home];
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

@if (!Model.Any())
{
    <div class="text-center py-12 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
        <h2 class="text-2xl font-bold text-slate-400 dark:text-slate-500">@Localizer[UIResourceKeys.SectionNoContent]</h2>
    </div>
}
else
{
    @foreach (var homePage in Model)
    {
        <section id="@homePage.Slug" class="mb-3">
            <div class="flex flex-col mb-3">
                <div class="mb-2">
                    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
                        @homePage.Title
                    </h2>
                    <div class="h-1.5 w-20 bg-brand-primary dark:bg-brand-accent rounded-full"></div>
                </div>
                @if (!string.IsNullOrEmpty(homePage.BodyHtml))
                {
                    <div class="ql-snow">
                        <div class="ql-editor">
                            @Html.Raw(homePage.BodyHtml)
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-12 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                        <h2 class="text-2xl font-bold text-slate-400 dark:text-slate-500">@homePage.Title</h2>
                        <p class="mt-2 text-slate-400 dark:text-slate-600">@Localizer[UIResourceKeys.SectionNoContent]</p>
                    </div>
                }
            </div>
        </section>
    }
}