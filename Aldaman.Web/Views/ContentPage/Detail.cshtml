@model Aldaman.Web.ViewModels.ContentPageViewModel
@{
    ViewData["Title"] = Model.Page.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl mb-8">@Model.Page.Title</h1>
    <div class="ql-snow">
        <div class="ql-editor p-0 text-slate-700 dark:text-slate-300">
            @if (!string.IsNullOrEmpty(Model.Page.BodyHtml))
            {
                @Html.Raw(Model.Page.BodyHtml)
            }
            else
            {
                <p class="text-slate-400 italic">No content available.</p>
            }
        </div>
    </div>
</div>
