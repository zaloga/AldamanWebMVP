@model Aldaman.Web.ViewModels.ContentPageViewModel
@{
    ViewData["Title"] = Model.Page.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/lib/quill/quill.snow.css" />
}
<section id="@Model.Page.Slug" class="border-b border-slate-200 dark:border-white/5 last:border-0">
    <div class="flex flex-col">
        <div class="mb-2">
            <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">
                @Model.Page.Title
            </h1>
            <div class="h-1.5 w-20 bg-brand-primary dark:bg-brand-accent rounded-full"></div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Page.BodyHtml))
        {
            <div class="ql-snow">
                <div class="ql-editor">
                    @Html.Raw(Model.Page.BodyHtml)
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-12 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700">
                <h2 class="text-2xl font-bold text-slate-400 dark:text-slate-500">@Model.Page.Title</h2>
                <p class="mt-2 text-slate-400 dark:text-slate-600">@Localizer[UIResourceKeys.SectionNoContent]</p>
            </div>
        }
    </div>
</section>