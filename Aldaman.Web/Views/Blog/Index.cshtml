@model Aldaman.Web.ViewModels.BlogListViewModel
@{
    ViewData["Title"] = Localizer[UIResourceKeys.Blog];
}

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">@Localizer[UIResourceKeys.Blog]</h2>
        <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 sm:mt-4">
            @Localizer[UIResourceKeys.BlogSubtitle]
        </p>
    </div>
    
    <div class="mt-12 max-w-lg mx-auto grid gap-5 lg:grid-cols-3 lg:max-w-none">
        @foreach (var post in Model.Posts.Items)
        {
            <div class="flex flex-col rounded-lg shadow-lg overflow-hidden">
                <div class="flex-shrink-0">
                    <img class="h-48 w-full object-cover" src="@(post.CoverImage?.RelativePath ?? "/images/placeholder.jpg")" alt="@post.Title">
                </div>
                <div class="flex-1 bg-white p-6 flex flex-col justify-between border border-gray-200">
                    <div class="flex-1">
                        <p class="text-sm font-medium text-indigo-600">
                            @Localizer[UIResourceKeys.Article]
                        </p>
                        <a href="/clanky/@post.Slug" class="block mt-2">
                            <p class="text-xl font-semibold text-gray-900">@post.Title</p>
                            <p class="mt-3 text-base text-gray-500">@post.Perex</p>
                        </a>
                    </div>
                    <div class="mt-6 flex items-center">
                        <div class="ml-3 p-0">
                            <p class="text-sm font-medium text-gray-900">
                                @(post.AuthorName ?? Localizer[UIResourceKeys.Administrator].Value)
                            </p>
                            <div class="flex space-x-1 text-sm text-gray-500">
                                <time datetime="@post.PublishedAtUtc?.ToString("yyyy-MM-dd")">
                                    @post.PublishedAtUtc?.ToString("d.M.yyyy")
                                </time>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
