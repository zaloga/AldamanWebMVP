@model Aldaman.Web.ViewModels.BlogListViewModel
@{
    ViewData["Title"] = Localizer[UIResourceKeys.Blog];
}

<div class="text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">@Localizer[UIResourceKeys.Blog]</h2>
    <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 sm:mt-4">
        @Localizer[UIResourceKeys.BlogSubtitle]
    </p>
</div>

<div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    @foreach (var post in Model.Posts.Items)
    {
        <a href="/blog/@post.Slug" class="group flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="h-48 w-full overflow-hidden bg-gray-100">
                <img class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                     src="@(post.CoverImageRelativePath ?? "/images/placeholder.jpg")"
                     alt="@post.Title">
            </div>

            <div class="flex flex-1 flex-col justify-between p-6">
                <div class="flex-1">
                    <h3 class="line-clamp-2 text-xl font-bold text-gray-950 transition-colors group-hover:text-blue-600">
                        @post.Title
                    </h3>
                    <p class="mt-3 line-clamp-3 text-sm/relaxed text-gray-600">
                        @post.Perex
                    </p>
                </div>

                <div class="mt-2 flex items-center gap-3 pt-4 border-t border-gray-50">
                    <div class="text-sm">
                        <div class="flex text-gray-500">
                            <time datetime="@post.PublishedAtUtc?.ToString("yyyy-MM-dd")">
                                @post.PublishedAtUtc?.ToString("d. M. yyyy")
                            </time>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    }
</div>
