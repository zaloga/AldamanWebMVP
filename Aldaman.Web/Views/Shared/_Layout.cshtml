<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aldaman</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // On page load or when changing themes, best to add inline in `head` to avoid FOUC
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>
<body class="flex flex-col min-h-full bg-brand-bg-light dark:bg-brand-bg-dark text-slate-900 dark:text-slate-100 transition-colors duration-300">
    <header class="glass sticky top-0 z-50 transition-colors duration-300">
        <nav class="container flex items-center justify-between h-16">
            <div class="flex items-center gap-8">
                <a class="text-xl font-bold tracking-tight text-slate-900 dark:text-white" asp-area="" asp-controller="Home" asp-action="Index">Aldaman</a>
                
                <div class="hidden md:flex items-center gap-6">
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Home" asp-action="Index">@Localizer[UIResourceKeys.Home]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Blog" asp-action="Index">@Localizer[UIResourceKeys.Blog]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.EventsSlug].Value">@Localizer[UIResourceKeys.Events]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.ShopSlug].Value">@Localizer[UIResourceKeys.Shop]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.GallerySlug].Value">@Localizer[UIResourceKeys.Gallery]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.OfferSlug].Value">@Localizer[UIResourceKeys.Offer]</a>
                    <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent transition-colors" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.PromoSlug].Value">@Localizer[UIResourceKeys.Promo]</a>
                    <a class="text-xl font-bold text-brand-primary dark:text-brand-accent hover:underline decoration-2 underline-offset-4 transition-all" asp-area="" asp-controller="Contact" asp-action="Index">@Localizer[UIResourceKeys.Contact]</a>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <button id="theme-toggle" type="button" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 focus:outline-none focus:ring-4 focus:ring-slate-200 dark:focus:ring-slate-700 rounded-lg text-sm p-2.5 transition-all">
                    <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                    <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.707.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464l-.707-.707a1 1 0 00-1.414 1.414l.707.707a1 1 0 001.414-1.414zm2.12 10.607a1 1 0 010-1.414l.707-.707a1 1 0 011.414 1.414l-.707.707a1 1 0 01-1.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zM3 10a1 1 0 100 2H4a1 1 0 100-2H3z"></path></svg>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="flex items-center gap-4">
                        <span class="hidden sm:inline text-xs text-slate-500 dark:text-slate-400">@User.Identity.Name</span>
                        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-sm font-semibold text-brand-primary dark:text-brand-accent hover:text-slate-900 dark:hover:text-white">@Localizer[UIResourceKeys.Admin]</a>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="inline">
                            <button type="submit" class="text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-brand-primary dark:hover:text-brand-accent border-l border-slate-200 dark:border-white/10 pl-4">@Localizer[UIResourceKeys.Logout]</button>
                        </form>
                    </div>
                }
                else
                {
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="btn-primary">@Localizer[UIResourceKeys.Login]</a>
                }
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow bg-brand-bg-light dark:bg-brand-bg-dark">
        @if (ViewData["FullWidth"] as bool? == true)
        {
            @RenderBody()
        }
        else
        {
            <div class="container py-12">
                @RenderBody()
            </div>
        }
    </main>

    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-slate-200 dark:border-white/10 py-10">
        <div class="container flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-sm text-slate-500 dark:text-slate-400">
                &copy; 2026 - @Localizer[UIResourceKeys.AldamanWebEssentials]
            </p>
            <div class="flex items-center gap-6">
                <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" asp-area="" asp-controller="Page" asp-action="Detail" asp-route-slug="@Localizer[UIResourceKeys.LinksSlug].Value">@Localizer[UIResourceKeys.Links]</a>
                <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white" asp-area="" asp-controller="Home" asp-action="Privacy">@Localizer[UIResourceKeys.PrivacyPolicy]</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
