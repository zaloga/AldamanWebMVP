<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aldaman</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="flex flex-col min-h-full">
    <header class="bg-white border-b border-slate-200">
        <nav class="container flex items-center justify-between h-16">
            <div class="flex items-center gap-8">
                <a class="text-xl font-bold tracking-tight text-slate-900" asp-area="" asp-controller="Home" asp-action="Index">Aldaman</a>
                
                <div class="hidden md:flex items-center gap-6">
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Home" asp-action="Index">@Localizer[UIResourceKeys.Home]</a>
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Home" asp-action="Privacy">@Localizer[UIResourceKeys.Privacy]</a>
                </div>
            </div>

            <div class="flex items-center gap-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="flex items-center gap-4">
                        <span class="hidden sm:inline text-xs text-slate-500">@User.Identity.Name</span>
                        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500">@Localizer[UIResourceKeys.Admin]</a>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="inline">
                            <button type="submit" class="text-xs font-medium text-slate-500 hover:text-slate-900 border-l border-slate-200 pl-4">@Localizer[UIResourceKeys.Logout]</button>
                        </form>
                    </div>
                }
                else
                {
                    <a asp-area="" asp-controller="Account" asp-action="Login" class="btn-primary">@Localizer[UIResourceKeys.Login]</a>
                }
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow py-12">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-slate-50 border-t border-slate-200 py-10">
        <div class="container flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-sm text-slate-500">
                &copy; 2026 - @Localizer[UIResourceKeys.AldamanWebEssentials]
            </p>
            <div class="flex items-center gap-6">
                <a class="text-sm text-slate-500 hover:text-slate-900" asp-area="" asp-controller="Home" asp-action="Privacy">@Localizer[UIResourceKeys.PrivacyPolicy]</a>
                <a href="#" class="text-sm text-slate-500 hover:text-slate-900">@Localizer[UIResourceKeys.TermsOfService]</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
