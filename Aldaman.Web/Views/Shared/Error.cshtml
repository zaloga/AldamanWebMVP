@model ErrorViewModel
@{
    ViewData["Title"] = Localizer[UIResourceKeys.Error];
}

<h1 class="text-danger">@Localizer[UIResourceKeys.Error].</h1>
<h2 class="text-danger">@Localizer[UIResourceKeys.ErrorOccurred]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@Localizer[UIResourceKeys.RequestId]</strong> <code>@Model.RequestId</code>
    </p>
}
